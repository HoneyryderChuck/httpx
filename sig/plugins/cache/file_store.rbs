module HTTPX
  module Plugins
    module Cache
      class FileStore
        CRLF: String

        @dir: Pathname

        include _CacheStore

        def initialize: (?path dir) -> void

        private

        def file_path: (cacheRequest request) -> Pathname

        def read_from_file: (cacheRequest request, File f) -> cacheResponse?
      end
    end
  end
end
